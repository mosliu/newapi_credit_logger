APP_NAME=NewAPI Credit Logger
APP_VERSION=0.1.2
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# SQLite/MySQL/PostgreSQL supported
DATABASE_URL=sqlite:///./data/newapi_credit_logger.db
# MySQL 示例（按需取消注释）
# DATABASE_URL=mysql+pymysql://app:app@127.0.0.1:3306/newapi_credit_logger
# PostgreSQL 示例（按需取消注释）
# DATABASE_URL=postgresql+psycopg://app:app@127.0.0.1:5432/newapi_credit_logger

LOG_DIR=logs
LOG_LEVEL=DEBUG
LOG_ROTATION=00:00
LOG_RETENTION=30 days
LOG_PREVIEW_LEN=220

DEFAULT_POLL_INTERVAL_SECONDS=300
DEFAULT_REQUEST_TIMEOUT_SECONDS=20
DEFAULT_REQUEST_RETRIES=2
# Scheduler: wait N seconds between scheduled upstream requests (0 to disable).
SCHEDULER_REQUEST_DELAY_SECONDS=1
# Scheduler: allow slight delays before marking the run as missed.
SCHEDULER_MISFIRE_GRACE_SECONDS=30
# Scheduler: thread pool size for scheduled jobs.
SCHEDULER_MAX_WORKERS=20

API_KEY_ENCRYPT_SECRET=change-me-in-production
ADMIN_PASSWORD=change-me-admin-password
ADMIN_SESSION_SECRET=change-me-admin-session-secret

# Public API tool rate limit
API_TOOL_RATE_LIMIT_PER_MINUTE=30

# API 可用性测试默认值
DEFAULT_TEST_CHANNEL=openai_responses
DEFAULT_CLI_PROFILE=codex
DEFAULT_OPENAI_BASE_URL=https://api.openai.com
DEFAULT_OPENAI_CHAT_MODEL=gpt-5.3-codex
DEFAULT_OPENAI_RESPONSES_MODEL=gpt-5.3-codex
DEFAULT_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
DEFAULT_GEMINI_MODEL=gemini-3-flash-preview
DEFAULT_CLAUDE_BASE_URL=https://api.anthropic.com
DEFAULT_CLAUDE_MODEL=claude-sonnet-4-6

# LLM 解析按钮后端配置（留空则前端提示未配置）
PARSER_LLM_CHANNEL=openai_chat
PARSER_LLM_BASE_URL=
PARSER_LLM_API_KEY=
PARSER_LLM_MODEL=
PARSER_LLM_TIMEOUT_SEC=30
PARSER_LLM_CLI_PROFILE=default

# Neko 查询配置
NEKO_BASE_URL=
NEKO_BASE_URLS={}
NEKO_DEFAULT_SITE_KEY=
NEKO_SHOW_BALANCE=true
NEKO_SHOW_DETAIL=true
NEKO_TIMEOUT_SEC=30
